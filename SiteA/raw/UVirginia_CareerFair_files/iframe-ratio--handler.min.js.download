
/**
 * @file
 * Handle setting the ratio for embedded iframes
 */

(function ($, Drupal) {
  $(function () {
    // Traverse all iframe elements
    $('iframe').each(function () {
      // Get its width and height attributes
      var iframeWidth = $(this).attr('width');
      var iframeHeight = $(this).attr('height');
      var w = parseInt(iframeWidth, 10);
      var h = parseInt(iframeHeight, 10);
      var style = ($(this).attr('style') || '').toLowerCase();

      // An iframe that does NOT have its width and height attributes set,
      // or has width of 0 and height of 0, do nothing.
      if (typeof iframeWidth == 'undefined' || typeof iframeHeight == 'undefined' || w === 0 || h === 0 || isNaN(w) || isNaN(h)) {
        // Do nothing
      }
      // Skip tiny / hidden iframes (analytics, tracking pixels, etc.) — not real embeds.
      else if ((w <= 4 && h <= 4) || (style.indexOf('visibility') !== -1 && style.indexOf('hidden') !== -1 && w <= 16 && h <= 16)) {
        // Do nothing
      }
      // Otherwise, wrap it inside a div.iframe-container (its parent)
      // and process the parent.
      else {
        $(this).wrap('<div class="iframe-container"></div>');
        var ratioPercentage = (h / w * 100).toFixed(2) + '%';
        var iframeAlignment = $(this).attr('align');
        if (iframeAlignment) {
          $(this).parent('.iframe-container').addClass('align-' + iframeAlignment);
        }
        $(this).parent('.iframe-container').append('<div class="iframe-ratio-setter" style="padding-top: ' + ratioPercentage + ';"></div>');
      }
    });
  });
})(jQuery, Drupal);

