
/**
 * @file
 * Handle the accodion components
 */

(function ($, Drupal) {

  // Create toggle elements and containers
  $(function() {
    if($('.view-banner-image img').length){
      $('#block-de-theme-page-title').hide()
    } else {
      $('.view-banner-image').hide();
    }

    //Change site title to H1 on homepage
    $('.path-frontpage #block-sitebranding-2 .site-name a').wrap('<h1></h1>');

  });

})(jQuery, Drupal);
