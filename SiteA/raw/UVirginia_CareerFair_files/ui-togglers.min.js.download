/**
 * @file
 * UI toggler elements control
 */

(function ($, Drupal) {


  // // ===== Add menu control to the custom close button in the mobile navigation panel
  // $(function () {
  //   $('.mm-navbar').append('<a href="#page" class="close-menu">Close Menu</a>');
  //   // Set the api variable and acess the mm-menu API
  //   const menu = new mmenu("#off-canvas");
  //   const api = menu.API;

  //   $('.close-menu').click(function () {
  //     $(this).preventDefault(); // Prevent default behavior
  //     api.close(); // Trigger mm-menu close function
  //   });
  // });

  $(function() {
    $('.mm-navbar').append('<a href="#page" class="close-menu">Close Menu</a>');
    // Set the api variable and acess the mm-menu API
    var api = $('#off-canvas').data('mmenu');
    $('.close-menu').click(function () {
      $(this).preventDefault(); // Prevent default behavior
      api.close(); // Trigger mm-menu close function
    });
  });
  // ===== Toggle and handle search input on mobile and mid screened devices

  $(function() {
    var $html = $('html');
    var $searchToggle = $('.block-search-toggle');
    var $searchBlock = $('#block-exposedformsearchpage');
    var $searchBlockInput = $('#edit-submit-search');


    function toggleSearch() {
      $searchBlock.toggleClass('show');
      $searchToggle.toggleClass('open');
      // $html.toggleClass('search-active').toggleClass('no-scroll');

      if ($searchBlock.hasClass('show')) {
        $searchBlockInput.focus();
      }
    }
    $searchToggle.click(toggleSearch);

    // Remove the visibility classes if scaling up from mobile
    ssm.addState({
      id: 'm-break',
      query: '(min-width: 900px)',
      onEnter: function() {
        if ($searchBlock.hasClass('show')) {
          $searchBlock.removeClass('show');
          $searchToggle.removeClass('open');
          // $html.removeClass('search-active').toggleClass('no-scroll');
        }
      }
    });
  });

  (function ($) {
    // ===== Updates for user login page

    $(function () {
      // SimpleSAML link moved above the content block
      $('#user-login-form #edit-simplesamlphp-auth-login-link')
        .prependTo('#block-de-theme-content');

      // Ensure the login form is visible
      $('#user-login-form').show();
    });

  })(jQuery);
})(jQuery, Drupal);
