/**
 * @file
 * Accessibility Modifications
 */

(function ($, Drupal) {
  $(function() {

    $('.path-frontpage .block-views-block--banner-image-banner-view-block h1').remove();

    $('.view-person .view-content > h3').replaceWith(function () {
      return "<h2>" + $(this).html() + "</h2>";
    });


    // Add title if embedded google map iframe does not have it or is empty
    function embeddedGoogleMapTitle() {
      const iframes = document.querySelectorAll('.block-inline-block--google-map iframe');

      Array.prototype.forEach.call(iframes, function (frame) {
        const title = frame.getAttribute('title');

        // Check if title is missing, empty, or only whitespace
        if (!title || title.trim() === '') {
          frame.setAttribute('title', 'Embedded Google Map');
        }
      });
    }

    document.addEventListener('DOMContentLoaded', embeddedGoogleMapTitle);

  });
})(jQuery, Drupal);
